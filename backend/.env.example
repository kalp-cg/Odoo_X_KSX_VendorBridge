# =========================================================================
# VendorBridge Backend - Environment Configuration
# Copy to .env (development) or .env.production and fill in real values.
# =========================================================================

# ---------- Application ----------
NODE_ENV=development
APP_NAME=vendorbridge
APP_PORT=4000
APP_GLOBAL_PREFIX=api/v1
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
APP_LOG_LEVEL=debug
APP_TIMEZONE=UTC

# ---------- Database (Postgres) ----------
# Owner role (full privileges; used for migrations, seeding, runtime app queries)
DATABASE_URL=postgresql://vb_owner:vb_owner_pwd@localhost:5432/vendorbridge?schema=public
# Restricted role for the application runtime (no UPDATE/DELETE on audit_logs).
# Used by PgBouncer / DSN in production; the same owner role is fine for local dev.
DATABASE_RUNTIME_URL=postgresql://vb_owner:vb_owner_pwd@localhost:5432/vendorbridge?schema=public

# ---------- JWT (RS256) ----------
# Paths are relative to the backend root. Generate via: pnpm keygen
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=vendorbridge
JWT_AUDIENCE=vendorbridge-clients

# ---------- Cookies ----------
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=vendorbridge

# ---------- File upload limits ----------
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME=application/pdf,image/png,image/jpeg,image/webp,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ---------- Auth lockout ----------
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_DURATION_MINUTES=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30

# ---------- Rate limiting ----------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
RATE_LIMIT_AUTH_MAX=10

# ---------- Business rules ----------
INVOICE_OVERDUE_AFTER_DAYS=30
INVOICE_CRON=0 9 * * *

# ---------- Email (optional in v1; console fallback) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@vendorbridge.local
SMTP_ENABLED=false
